# ---------------------------------------------------------------------------
# Podman Panel configuration
# Copy to .env.local for local development, or pass as environment to the
# container in production. Never commit real secrets.
# ---------------------------------------------------------------------------

# Path to the Podman (or Docker-compatible) API socket.
# Rootless Podman (typical):   /run/user/1000/podman/podman.sock
# Rootful Podman:              /run/podman/podman.sock
# Docker (for local testing):  /var/run/docker.sock
PODMAN_SOCKET_PATH=/run/podman/podman.sock

# Secret used to sign/derive session identifiers and CSRF tokens.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED in production. The app refuses to start without it when NODE_ENV=production.
SESSION_SECRET=change-me-to-a-long-random-value

# Directory where the SQLite database is stored. Mount this as a volume.
DATA_DIR=./data

# HTTP port the dashboard listens on.
PORT=3000

# Bootstrap admin account, created on first startup if no users exist.
# Change the password immediately after first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Session lifetimes (seconds).
SESSION_IDLE_TIMEOUT=1800        # 30 min inactivity timeout
SESSION_ABSOLUTE_TIMEOUT=43200   # 12 h absolute maximum lifetime

# Set to "true" only when served over HTTPS so the session cookie gets the
# Secure flag. Leave false for plain-http local development.
COOKIE_SECURE=false

# Key used to encrypt stored secrets (AES-256-GCM). If unset, it is derived
# from SESSION_SECRET — but then rotating SESSION_SECRET makes existing secrets
# undecryptable. Set this explicitly to keep them independent.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SECRETS_KEY=

# Compose CLI used to deploy stacks. Empty = auto ("docker compose").
# The Docker image bundles the standalone binary and sets this to "docker-compose".
# For rootless Podman you might use: COMPOSE_COMMAND="podman compose"
COMPOSE_COMMAND=
